# Copy this file to .env.qa.local and fill in disposable QA accounts.
# .env.qa.local is ignored by Git because .env* is ignored.

LIVE_BASE_URL=https://clientbureau.com

# Contractor/business-owner QA account.
# Use a disposable account that can safely create private test jobs,
# reports, contracts, recovery cases, lien cases, evidence records, and watchlist items.
CONTRACTOR_QA_EMAIL=contractor-qa@example.com
CONTRACTOR_QA_PASSWORD=replace-with-private-password

# Admin QA account.
# Use a disposable admin account promoted in Supabase for report/profile/admin smoke tests.
ADMIN_QA_EMAIL=admin-qa@example.com
ADMIN_QA_PASSWORD=replace-with-private-password
