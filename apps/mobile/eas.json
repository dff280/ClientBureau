{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview-apk": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://clientbureau.com",
        "EXPO_PUBLIC_SITE_URL": "https://clientbureau.com"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production-aab": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://clientbureau.com",
        "EXPO_PUBLIC_SITE_URL": "https://clientbureau.com"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
